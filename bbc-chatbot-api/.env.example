# BBC Chatbot API — Environment Variables
# Copy to .env and fill in real values

# === REQUIRED ===
SUPABASE_URL=https://exwxdjfeoekfixnjsreq.supabase.co
SUPABASE_KEY=eyJ...your_service_role_key_here

# === AUTH (empty = dev mode, no auth) ===
API_USER=admin
API_PASS=change_me_in_production

# === AI (required for chatbot, optional for admin-only mode) ===
ANTHROPIC_API_KEY=sk-ant-...

# === OPTIONAL ===
DEBUG=false
DAILY_BUDGET=50.0
QDRANT_URL=
QDRANT_API_KEY=
REDIS_URL=
